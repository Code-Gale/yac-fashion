# Copy to deploy/deploy.env and edit (used by scripts/deploy-vps.sh)
# Paths are relative to repo root when you run the script from there.

# Public hostnames (no https://)
YAC_SITE_HOST=yac.voidgrid.com
YAC_API_HOST=api.yac.voidgrid.com

# Let's Encrypt: email for expiry notices (required for certbot)
CERT_EMAIL=you@example.com

# After certbot, certificate files usually live here (first -d domain = folder name)
# If you only issued for api subdomain, set this to that folder name.
CERT_DIR_NAME=yac.voidgrid.com
